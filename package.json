{
  "name": "project-avatar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*",
    "relay",
    "web",
    "skill"
  ],
  "scripts": {
    "relay:dev": "cd relay && npm run dev",
    "relay:deploy": "cd relay && npm run deploy",
    "gen:skill": "npx tsx scripts/gen-skill-md.ts",
    "relay:test": "cd relay && npm run test",
    "skill:test": "cd skill && npm run test",
    "plugin:test": "cd packages/openclaw-plugin && npm run test",
    "plugin:build": "cd packages/openclaw-plugin && npm run build",
    "test": "npm run relay:test && npm run skill:test && npm run plugin:test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0"
  }
}
