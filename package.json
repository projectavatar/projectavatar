{
  "name": "project-avatar",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "dev": "cd packages/web && npm run dev",
    "relay:dev": "cd packages/relay && npm run dev",
    "relay:deploy": "cd packages/relay && npm run deploy",
    "relay:test": "cd packages/relay && npm run test",
    "plugin:test": "cd packages/openclaw-avatar && npm run test",
    "plugin:build": "cd packages/openclaw-avatar && npm run build",
    "test": "npm run relay:test && npm run plugin:test",
    "changeset": "changeset",
    "version": "changeset version",
    "release": "changeset publish",
    "clips": "cd packages/clip-manager && npm run dev",
    "clips:gen": "npx tsx scripts/generate-clips-json.ts",
    "desktop": "cd packages/desktop && npm run tauri dev",
    "desktop:build": "cd packages/desktop && npm run tauri build"
  },
  "devDependencies": {
    "@changesets/cli": "^2.29.8",
    "@types/node": "^25.3.2",
    "tsx": "^4.21.0"
  }
}
