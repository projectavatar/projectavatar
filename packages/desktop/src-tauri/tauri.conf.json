{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Project Avatar",
  "version": "0.6.3",
  "identifier": "io.projectavatar.desktop",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project Avatar",
        "width": 400,
        "height": 600,
        "minWidth": 200,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": true,
        "shadow": false,
        "backgroundColor": [
          0,
          0,
          0,
          0
        ],
        "devtools": true
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' http://ipc.localhost blob: https://app.projectavatar.io wss://relay.projectavatar.io https://relay.projectavatar.io ws://localhost:* http://localhost:*; img-src 'self' blob: data: https:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDExRjJCMUMyNjI5QjRERjQKUldUMFRadGl3ckh5RVJtdk9iejFJODV5bW0yNmE0Tnp1UXc5RVRMMEZJbVhSTkZjNTlKaEVaTGkK",
      "endpoints": [
        "https://github.com/projectavatar/projectavatar/releases/latest/download/latest.json"
      ]
    }
  }
}
