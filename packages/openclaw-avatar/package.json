{
  "name": "@projectavatar/openclaw-avatar",
  "version": "1.2.0",
  "description": "Real-time 3D avatar driven by OpenClaw agent lifecycle hooks. Your agent gets a face.",
  "repository": {
    "type": "git",
    "url": "https://github.com/projectavatar/projectavatar.git",
    "directory": "packages/openclaw-avatar"
  },
  "type": "module",
  "main": "src/index.ts",
  "exports": {
    ".": "./src/index.ts"
  },
  "openclaw": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "files": [
    "src",
    "openclaw.plugin.json"
  ],
  "scripts": {
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "vitest": "^1.6.0"
  },
  "peerDependencies": {
    "openclaw": "*"
  },
  "peerDependenciesMeta": {
    "openclaw": {
      "optional": true
    }
  },
  "keywords": [
    "openclaw",
    "openclaw-avatar",
    "avatar",
    "projectavatar",
    "vrm",
    "llm",
    "agent"
  ],
  "license": "AGPL-3.0-or-later"
}
