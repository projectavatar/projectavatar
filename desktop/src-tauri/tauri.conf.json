{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-utils/schema.json",
  "productName": "Project Avatar",
  "version": "0.1.0",
  "identifier": "day.uniq.project-avatar",
  "build": {
    "beforeBuildCommand": "npm run build",
    "beforeDevCommand": "npm run dev",
    "devUrl": "http://localhost:5173",
    "frontendDist": "../dist"
  },
  "app": {
    "windows": [
      {
        "title": "Project Avatar",
        "width": 400,
        "height": 600,
        "minWidth": 200,
        "minHeight": 200,
        "decorations": false,
        "transparent": true,
        "resizable": true,
        "alwaysOnTop": true,
        "shadow": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; script-src 'self' 'unsafe-inline'; style-src 'self' 'unsafe-inline'; connect-src 'self' wss://relay.projectavatar.io https://relay.projectavatar.io ws://localhost:* http://localhost:*; img-src 'self' blob: data: https:; font-src 'self' data:; worker-src 'self' blob:"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "createUpdaterArtifacts": true
  },
  "plugins": {
    "updater": {
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IDE2N0M2NUZENzVERTQ2NDUKUldSRlJ0NTEvV1Y4RmhUSGRqVHQ1WXNPY3Bzc05KNmgzcVVYOEV0eUl1V3ZCaUVKeEdBTk0ycHoK",
      "endpoints": [
        "https://github.com/linh-n/projectavatar/releases/latest/download/latest.json"
      ]
    }
  }
}
